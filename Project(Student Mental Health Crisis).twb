      <aliases enabled='yes' />
      <column caption='Cgpa' datatype='real' name='[CGPA]' role='measure' type='quantitative' />
      <column caption='01_Total_respondant_KPI' datatype='integer' name='[Calculation_0599837941137408]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([id])' />
      </column>
      <column caption='02_Depression_Ratio_Percentage' datatype='real' name='[Calculation_0599837942702081]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Depression])/COUNT([id])' />
      </column>
      <column caption='03_Avg_Anxity_Pressure' datatype='real' name='[Calculation_0599837944315906]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Academic Pressure]+[Financial Stress]+[Work Pressure])/3' />
      </column>
      <column caption='03_Anxity_Ratio' datatype='real' name='[Calculation_0599837944860675]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Calculation_0599837944315906]&gt;=2.5&#13;&#10;THEN 1 &#13;&#10;ELSE 0&#13;&#10;END)/COUNT([id])' />
      </column>
      <column caption='04_High_Financial_Stress' datatype='real' name='[Calculation_0599837946187780]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Financial Stress]&gt;=4&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)/COUNT([id])' />
      </column>
      <column caption='01_Sleep_Duration' datatype='string' name='[Calculation_0599837990457350]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='REPLACE([Sleep Duration],&quot;&apos;&quot;, &quot; &quot;)' />
      </column>
      <column caption='05_Low_Sleep_Duration' datatype='real' name='[Calculation_0599837991698440]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Calculation_0599837990457350]=&quot; Less than 5 hours &quot; or [Calculation_0599837990457350]=&quot; 5-6 hours &quot;&#13;&#10;THEN 1 &#13;&#10;ELSE 0 &#13;&#10;END&#13;&#10;)/COUNT([id])' />
      </column>
      <column caption='02_Depression' datatype='string' name='[Calculation_0599837994024969]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Depression]=1 THEN &quot;Depressed&quot;&#13;&#10;ELSE &quot;Not Depressed&quot;&#13;&#10;END' />
      </column>
      <column caption='03_Financial_Stress_Category' datatype='string' name='[Calculation_0599838002106378]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Financial Stress]&lt;=2 &#13;&#10;THEN &quot;Low Stress&quot;&#13;&#10;ELSEIF [Financial Stress]=3&#13;&#10;THEN &quot;Moderate Stress&quot;&#13;&#10;ELSE &quot;High Stress&quot;&#13;&#10;END' />
      </column>
      <column caption='04_Work_Pressure_Bar' datatype='string' name='[Calculation_0599838529986571]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Work/Study Hours]&lt;=4 THEN &quot;0-4 Hours&quot;&#13;&#10;ELSEIF [Work/Study Hours]&lt;=6 THEN &quot;4-6 Hours&quot;&#13;&#10;ELSEIF [Work/Study Hours]&lt;=8 THEN &quot;6-8 Hours&quot;&#13;&#10;ELSEIF [Work/Study Hours]&lt;=10 THEN &quot;8-10 Hours&quot;&#13;&#10;ELSE &quot;10+ Hours&quot; END' />
      </column>
